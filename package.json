{
  "name": "spiral-boss-codex",
  "version": "1.0.0",
  "description": "Wizard101 boss cheat database with fuzzy + semantic search",
  "type": "module",
  "scripts": {
    "build": "esbuild site/src/app.js --bundle --format=esm --minify --external:https://* --outfile=site/app.js",
    "dev": "esbuild site/src/app.js --bundle --format=esm --external:https://* --outfile=site/app.js --servedir=site",
    "enrich": ".venv/bin/python scripts/4_enrich.py && node scripts/5_embed.mjs && npm run build"
  },
  "keywords": ["wizard101", "boss", "cheats", "semantic-search"],
  "license": "MIT",
  "dependencies": {
    "esbuild": "^0.28.1",
    "minisearch": "^7.2.0"
  },
  "devDependencies": {
    "@xenova/transformers": "^2.17.2"
  }
}
